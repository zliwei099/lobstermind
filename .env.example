LOBSTERMIND_PORT=8787
LOBSTERMIND_HOST=127.0.0.1
LOBSTERMIND_DATA_DIR=./data
LOBSTERMIND_HTTP_ENABLED=true
LOBSTERMIND_APPROVAL_MODE=dangerous
LOBSTERMIND_SHELL_TIMEOUT_MS=15000
LOBSTERMIND_FEISHU_VERIFICATION_TOKEN=
LOBSTERMIND_FEISHU_BOT_NAME=LobsterMind
LOBSTERMIND_FEISHU_MODE=long-connection
LOBSTERMIND_FEISHU_LONG_CONNECTION_MODE=stub
LOBSTERMIND_FEISHU_LONG_CONNECTION_ADAPTER=official
LOBSTERMIND_FEISHU_APP_ID=
LOBSTERMIND_FEISHU_APP_SECRET=
# Only needed when LOBSTERMIND_FEISHU_LONG_CONNECTION_ADAPTER=relay
LOBSTERMIND_FEISHU_WS_URL=
LOBSTERMIND_FEISHU_API_BASE_URL=https://open.feishu.cn/open-apis
LOBSTERMIND_FEISHU_STUB_INBOX_PATH=./data/feishu-stub-inbox.jsonl
LOBSTERMIND_FEISHU_STUB_OUTBOX_PATH=./data/feishu-stub-outbox.jsonl
LOBSTERMIND_FEISHU_STUB_POLL_MS=2000
LOBSTERMIND_SHELL_ALLOWLIST=echo,pwd,ls,open
LOBSTERMIND_BRAIN_ENABLED=false
LOBSTERMIND_BRAIN_PROVIDER=codex
LOBSTERMIND_BRAIN_MODEL=gpt-5.4
